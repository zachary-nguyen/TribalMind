# TribalMind Configuration
# Copy to .tribal/config.yaml in your project root and customize.
# Values here are overridden by TRIBAL_* environment variables.

# Backboard API settings
# backboard_base_url: "https://app.backboard.io/api"
# API key should be set via: tribal config set-secret backboard-api-key

# LLM provider and model (used for parsing memories via Backboard)
# Supported providers: anthropic, openai, google
llm_provider: "anthropic"
model_name: "claude-sonnet-4-20250514"

# Project assistant ID (set automatically by `tribal init`)
# project_assistant_id: "your-assistant-id"
